{
  "expo": {
    "name": "Mitimiti",
    "slug": "mitimiti",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": [
      "ios",
      "android"
    ],
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "backgroundColor": "#FAF6EB",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mitimiti.app"
    },
    "android": {
      "package": "com.mitimiti.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FAF6EB"
      }
    },
    "extra": {
      "eas": {
        "projectId": "73bfd4b3-577d-46ff-8081-4964efc869bc"
      }
    }
  }
}
